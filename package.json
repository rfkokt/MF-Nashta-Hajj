{
  "name": "@my-saas/root",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=4",
    "dev:shell": "nx serve shell",
    "dev:auth": "nx serve auth-mfe",
    "build": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "test": "nx run-many --target=test --all",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint-plugin": "^22.5.2",
    "@nx/jest": "22.5.2",
    "@nx/js": "22.5.2",
    "@nx/plugin": "^22.5.2",
    "@nx/vite": "^22.5.2",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.2.7",
    "nx": "^22.5.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nx/devkit": "22.5.2"
  }
}
